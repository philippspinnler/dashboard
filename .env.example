# ─────────────────────────────────────────────────────────────────────────────
# Dashboard (Nuxt) configuration.
# Copy to `.env` and fill in. All values are also injectable at container runtime
# via the same NUXT_* / NUXT_PUBLIC_* names (no rebuild needed).
# ─────────────────────────────────────────────────────────────────────────────

# --- Layout (public) ---
# Available widgets: clock, calendar, presence, internet, netatmo,
#                    public-transportation, eo-guide, weather, cars, inverter
# (Sonos is not a grid widget — it shows as a corner overlay; see below.)
NUXT_PUBLIC_WIDGETS_TOP_LEFT=clock
NUXT_PUBLIC_WIDGETS_TOP_RIGHT=
NUXT_PUBLIC_WIDGETS_LEFT=calendar
NUXT_PUBLIC_WIDGETS_RIGHT=heizung,presence,internet,netatmo,public-transportation,eo-guide
NUXT_PUBLIC_WIDGETS_BOTTOM=weather

NUXT_PUBLIC_ENABLE_GLASSMORPHISM=false

# Serve built-in mock payloads instead of calling real services (offline dev)
NUXT_PUBLIC_USE_MOCK_DATA=false

# --- Weather (OpenWeatherMap One Call 3.0) ---
NUXT_WEATHER_API_KEY=
# Default location for the weather widget (decimal degrees)
NUXT_WEATHER_DEFAULT_LAT=
NUXT_WEATHER_DEFAULT_LON=

# --- Locale ---
# IANA timezone for calendar date math (e.g. America/New_York); defaults to UTC
NUXT_TIMEZONE=UTC

# --- Home Assistant (presence, netatmo, cars, inverter) ---
NUXT_HOME_ASSISTANT_URL=
NUXT_HOME_ASSISTANT_TOKEN=
NUXT_HOME_ASSISTANT_PERSON_ENTITIES=person.alice,person.bob

# --- Doorbell live-feed overlay (UniFi Protect G6 Entry via Home Assistant) ---
# Shows the live camera feed top-right when the doorbell is pressed.
NUXT_PUBLIC_DOORBELL_ENABLED=false
# Doorbell-press entity: the event.<name>_doorbell (device_class: doorbell,
# event_types: ring) — its state becomes a fresh timestamp on each ring.
NUXT_DOORBELL_EVENT_ENTITY=event.eingang_g6_entry_doorbell
# Camera entity for the live stream.
NUXT_DOORBELL_CAMERA_ENTITY=camera.eingang_g6_entry_high_resolution_channel
NUXT_PUBLIC_DOORBELL_POLL_MS=1500
NUXT_PUBLIC_DOORBELL_OVERLAY_SECONDS=60

# --- Netatmo (via Home Assistant entities) ---
NUXT_NETATMO_INDOOR_TEMPERATURE_ENTITY=sensor.indoor_temperature
NUXT_NETATMO_INDOOR_CO2_ENTITY=sensor.indoor_carbon_dioxide
NUXT_NETATMO_OUTDOOR_TEMPERATURE_ENTITY=sensor.outdoor_temperature

# --- Sonos now-playing overlay (via Home Assistant media_player entities) ---
# Shows a compact now-playing card in a corner only while a speaker is playing.
# Comma-separated HA media_player entity ids; the first one that is playing wins.
NUXT_SONOS_MEDIA_PLAYERS=media_player.living_room,media_player.kitchen
NUXT_PUBLIC_SONOS_OVERLAY_ENABLED=true
# Corner: top-left | top-right | bottom-left | bottom-right
NUXT_PUBLIC_SONOS_OVERLAY_POSITION=bottom-right

# --- Low-battery overlay (via Home Assistant device_class: battery entities) ---
# Lists battery entities at/below the threshold in a corner while any are low.
NUXT_BATTERY_THRESHOLD=25
NUXT_PUBLIC_BATTERY_OVERLAY_ENABLED=true
# Corner: top-left | top-right | bottom-left | bottom-right
NUXT_PUBLIC_BATTERY_OVERLAY_POSITION=bottom-left

# --- Calendars (JSON array of { name, color, icalUrl }) ---
NUXT_CALENDARS_JSON=[]

# --- Public transportation (JSON array of [from, to, "direct"|"..."]) ---
NUXT_TRANSPORT_CONNECTIONS_JSON=[["Station A", "Station B", "direct"]]

# --- Speedtest (JSON array of { host, port, provider }) ---
# NUXT_SPEEDTEST_SOURCE selects how each host's /api/speedtest/latest is parsed:
#   speedtest-tracker (default) | iperf (self-hosted iperf3 collector)
NUXT_SPEEDTEST_SOURCE=speedtest-tracker
NUXT_SPEEDTESTS_JSON=[]

# --- Cars (JSON array of HA-entity-backed cars; empty if none) ---
# [{ "name": "...", "range_entity": "...", "state_of_charge_entity": "...",
#    "charging_active_entity": "...", "charging_power_entity": "...",
#    "end_of_charge_entity": "..." }]
NUXT_CARS_JSON=[]

# --- Inverter (Home Assistant entity ids; empty -> widget shows zeros) ---
# The widget wants power in watts; set POWER_SCALE=1000 if your entities are kW
# (e.g. SigenStor: sensor.sigen_plant_pv_power / _consumed_power /
#  _grid_import_power / _grid_export_power / _battery_state_of_charge).
NUXT_INVERTER_PV_POWER_ENTITY=
NUXT_INVERTER_POWER_CONSUMPTION_ENTITY=
NUXT_INVERTER_GRID_CONSUMPTION_ENTITY=
NUXT_INVERTER_GRID_FEEDIN_ENTITY=
NUXT_INVERTER_BATTERY_STATE_OF_CHARGE_ENTITY=
# signed battery power (+ charging / - discharging) — drives the charge indicator
NUXT_INVERTER_BATTERY_POWER_ENTITY=
# set true if your inverter reports battery power with the opposite sign
# (positive = discharging). Flips it so + = charging again.
NUXT_INVERTER_INVERT_BATTERY_POWER=false
NUXT_INVERTER_POWER_SCALE=1

# --- Heizung (Stiebel Eltron ISG heat pump via Home Assistant) ---
# Defaults match the stiebel_eltron_isg integration's entity ids; override if
# yours differ (e.g. HK2 instead of HK1). State = Kühlt if is_cooling, else
# Heizt if is_heating, else Bereit. Room target uses the comfort target (the
# live target drops to ~5° in summer mode).
NUXT_HEIZUNG_IS_HEATING_ENTITY=binary_sensor.stiebel_eltron_isg_is_heating
NUXT_HEIZUNG_IS_COOLING_ENTITY=binary_sensor.stiebel_eltron_isg_is_cooling
NUXT_HEIZUNG_ROOM_ACTUAL_ENTITY=sensor.stiebel_eltron_isg_actual_temperature_hk_1
NUXT_HEIZUNG_ROOM_TARGET_ENTITY=number.stiebel_eltron_isg_comfort_temperature_target_hk1
NUXT_HEIZUNG_OUTDOOR_ENTITY=sensor.stiebel_eltron_isg_outdoor_temperature

# --- Photo album background: 'immich' (default) or 'icloud' ---
NUXT_ALBUM_PROVIDER=immich
NUXT_ICLOUD_ALBUM_ID=
NUXT_IMMICH_URL=
NUXT_IMMICH_API_KEY=
NUXT_IMMICH_SHARE_KEY=
NUXT_IMMICH_ALBUM_NAME=
NUXT_IMMICH_C=

# --- eo-guide (AppFigures) ---
NUXT_EOGUIDE_CLIENT_KEY=
NUXT_EOGUIDE_USERNAME=
NUXT_EOGUIDE_PASSWORD=
